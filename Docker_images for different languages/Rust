# Rust also producces binaries 

FROM rust:1.76 AS build 
WORKDIR /app
COPY . . 
RUN cargo build --release   # this tells the cargo to build in release mode 
FROM debian:bookworm-slim
COPY --from=build /app/target/release/app /app   
CMD ["/app"]


